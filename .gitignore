# OS / Editor
.DS_Store
.idea/
.vscode/
*.swp

# Ruby / Rails
/.bundle
/vendor/bundle
/log/*
!/log/.keep
/tmp/*
!/tmp/.keep
/storage/*
!/storage/.keep
/public/assets
/public/packs
/public/packs-test

# Env / secrets
.env
.env.*
!.env.example
/config/master.key
/config/credentials/*.key

# Sorbet generated RBIs are committed so CI doesn't need to run
# `tapioca gems` / `tapioca dsl` (which requires the DB) before
# `srb tc`. Regenerate locally after gem upgrades.

# Tests / coverage
/coverage
/spec/tmp
/spec/examples.txt

# Cypress
/cypress/screenshots
/cypress/videos
/cypress/downloads
node_modules/

# Docs
/doc/
/.yardoc/
# MkDocs build output: generated by `mkdocs build`, deployed to GH
# Pages from CI. Local builds drop it here.
/site/
docker-compose.preview.yml
