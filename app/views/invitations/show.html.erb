<% content_for :title, t("invitation.title") %>
<div class="card card-elev" style="max-width:420px;margin:var(--sp-9) auto">
  <div class="eyebrow"><%= t("app_name") %></div>
  <h2><%= t("invitation.title") %></h2>
  <p><%= t("invitation.intro", household: @invitation.household.name, email: @invitation.email) %></p>
  <%= form_with model: @user, url: invitation_path(token: @token), method: :patch, local: true do |f| %>
    <% if @user.errors.any? %>
      <div class="flash alert"><%= @user.errors.full_messages.to_sentence %></div>
    <% end %>
    <p><%= f.label :name, t("activerecord.attributes.user.name") %><br>
       <%= f.text_field :name, style: "width:100%" %></p>
    <p><%= f.label :password, t("activerecord.attributes.user.password") %><br>
       <%= f.password_field :password, required: true, style: "width:100%" %></p>
    <p><%= f.label :password_confirmation, t("activerecord.attributes.user.password_confirmation") %><br>
       <%= f.password_field :password_confirmation, required: true, style: "width:100%" %></p>
    <p><%= f.submit t("invitation.accept_button"), class: "btn" %></p>
  <% end %>
</div>
