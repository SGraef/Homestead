<% content_for :title, t("price.title") %>
<h1><%= t("price.title") %>: <%= @product.name %></h1>
<p><%= link_to t("price.new_button"), new_product_price_path(@product), class: "btn" %>
   <%= link_to t("price.back_to_product"), @product, class: "btn secondary" %></p>

<table>
  <thead>
    <tr>
      <th><%= t("price.table.store") %></th>
      <th><%= t("price.table.amount") %></th>
      <th><%= t("price.table.normalized") %></th>
      <th><%= t("price.table.observed_on") %></th>
      <th><%= t("price.table.source") %></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @prices.each do |p| %>
      <tr>
        <td><%= p.store.name %></td>
        <td><%= number_to_currency(p.amount, unit: p.currency) %></td>
        <td class="mono"><%= normalized_price(p) || "—" %></td>
        <td><%= l(p.observed_on) %></td>
        <td><%= t("price.sources.#{p.source}", default: p.source) %></td>
        <td>
          <%= link_to t("common.edit"), edit_product_price_path(@product, p) %>
          ·
          <%= button_to t("common.delete"), product_price_path(@product, p), method: :delete,
              class: "btn warn", data: { turbo_confirm: t("common.delete_confirm") } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
