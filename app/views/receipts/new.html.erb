<% content_for :title, t("receipt.new_title") %>
<h1><%= t("receipt.new_title") %></h1>

<div class="card">
  <%= form_with model: @receipt, url: receipts_path, multipart: true, local: true do |f| %>
    <% if @receipt.errors.any? %>
      <div class="flash alert"><%= @receipt.errors.full_messages.to_sentence %></div>
    <% end %>
    <p>
      <%= f.label :image, t("receipt.image_label") %><br>
      <%# `capture="environment"` opens the rear camera on phones for photos;
          desktop browsers ignore it and just show the standard file picker, which
          can also pick PDFs thanks to the broadened `accept`. %>
      <%= f.file_field :image,
                       accept: "image/jpeg,image/png,image/webp,image/heic,image/heif,application/pdf",
                       capture: "environment",
                       required: true %>
    </p>
    <p class="caption"><%= t("receipt.image_help") %></p>
    <p><%= t("receipt.upload_hint") %></p>
    <p><%= f.submit t("receipt.upload_button"), class: "btn" %></p>
  <% end %>
</div>
