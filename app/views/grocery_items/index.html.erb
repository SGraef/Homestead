<% content_for :title, t("grocery.title") %>
<h1><%= t("grocery.title") %></h1>
<p>
  <%= link_to t("grocery.add_item"), new_grocery_item_path, class: "btn" %>
  <%= link_to t("grocery.scan_to_purchase"), scan_products_path, class: "btn secondary" %>
  <% if current_household.bring_connected? %>
    <%= link_to t("bring.synced_to", list: current_household.bring_connection.default_list_name.presence || "Bring!"),
                bring_connection_path, class: "chip success" %>
  <% else %>
    <%= link_to t("bring.connect_cta"), new_bring_connection_path, class: "chip" %>
  <% end %>
</p>

<div style="display:flex;flex-wrap:wrap;gap:var(--sp-2);align-items:center;margin-bottom:var(--sp-3)">
  <%= link_to t("grocery.filter.only_needed"),
              grocery_items_path,
              class: ("chip #{'chip-active' unless @show_purchased}").strip %>
  <%= link_to t("grocery.filter.all"),
              grocery_items_path(show_purchased: 1),
              class: ("chip #{'chip-active' if @show_purchased}").strip %>

  <% if @purchased_count.positive? %>
    <span style="margin-left:auto"></span>
    <%= button_to t("grocery.purge_purchased", count: @purchased_count),
                  purge_purchased_grocery_items_path,
                  method: :delete,
                  class: "btn btn-sm warn",
                  data: { turbo_confirm: t("grocery.purge_confirm", count: @purchased_count) } %>
  <% end %>
</div>

<table>
  <thead>
    <tr>
      <th><%= t("grocery.table.product") %></th>
      <th><%= t("grocery.table.quantity") %></th>
      <th><%= t("grocery.table.status") %></th>
      <th><%= t("grocery.table.store") %></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @items.each do |i| %>
      <% offer = i.product_id ? @best_offer_by_product[i.product_id] : nil %>
      <tr id="grocery_item_<%= i.id %>">
        <td>
          <%= i.display_name %>
          <% if i.product_id.nil? %>
            <span class="pill" title="<%= t('grocery.row.freeform_help') %>"><%= t("grocery.row.freeform") %></span>
          <% end %>
          <% if offer %>
            <%= link_to offers_path(anchor: "offer-#{offer.id}"),
                        class: "chip success",
                        title: t("grocery.offer_match.tooltip",
                                 retailer: offer.retailer_name,
                                 until: l(offer.valid_until)) do %>
              <%= t("grocery.offer_match.label",
                    price: number_to_currency(offer.price_cents / 100.0, unit: offer.currency),
                    retailer: offer.retailer_name) %>
            <% end %>
          <% end %>
        </td>
        <td>
          <%= i.quantity %>
          <% if i.product %><%= t("product.units.#{i.product.unit}", default: i.product.unit) %><% end %>
        </td>
        <td><span class="pill <%= 'warn' if i.status == 'needed' %>">
          <%= t("grocery.statuses.#{i.status}", default: i.status) %>
        </span></td>
        <td><%= i.store&.name %></td>
        <td>
          <% if i.status == "needed" %>
            <%= button_to t("grocery.mark_purchased"), purchase_grocery_item_path(i), method: :patch, class: "btn" %>
          <% end %>
          <%= link_to t("common.edit"), edit_grocery_item_path(i) %>
        </td>
      </tr>
    <% end %>

    <%# Watchlist items shown inline in the same list, tinted with the accent
        colour to mark them as "watched" rather than split into a group. %>
    <% @watched.each do |w| %>
      <% offer = @watched_offers[w.id] %>
      <tr style="background:var(--accent-soft)">
        <td>
          <%= w.pattern %>
          <% if offer %>
            <%= link_to offers_path(anchor: "offer-#{offer.id}"), class: "chip success",
                        title: (offer.valid_until ? t("grocery.offer_match.tooltip", retailer: offer.retailer_name, until: l(offer.valid_until)) : offer.retailer_name) do %>
              <%= t("grocery.offer_match.label",
                    price: number_to_currency(offer.price_cents / 100.0, unit: offer.currency),
                    retailer: offer.retailer_name) %>
            <% end %>
          <% end %>
        </td>
        <td></td>
        <td>
          <span class="pill" style="background:var(--accent-soft-hover);color:var(--accent-soft-text)">
            <%= t("grocery.watched.badge") %>
          </span>
        </td>
        <td></td>
        <td>
          <%= button_to t("grocery.watched.add"), grocery_items_path,
                        params: { grocery_item: { name: w.pattern, quantity: 1 } },
                        class: "btn btn-sm", form: { style: "display:inline" } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
