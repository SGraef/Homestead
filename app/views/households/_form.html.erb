<%= form_with model: @household, url: household_path, method: :patch, local: true do |f| %>
  <% if @household.errors.any? %>
    <div class="flash alert"><%= @household.errors.full_messages.to_sentence %></div>
  <% end %>
  <p><%= f.label :name %><br><%= f.text_field :name, required: true %></p>
  <p><%= f.label :timezone %><br><%= f.text_field :timezone, value: @household.timezone || "UTC" %></p>
  <p>
    <%= f.label :postal_code %><br>
    <%= f.text_field :postal_code, placeholder: "10115" %><br>
    <span class="caption"><%= t("household.postal_code_hint") %></span>
  </p>
  <p>
    <%= f.label :flaschenpost_warehouse_id, t("household.flaschenpost_warehouse_id") %><br>
    <%= f.number_field :flaschenpost_warehouse_id, min: 1, placeholder: "1" %><br>
    <span class="caption"><%= t("household.flaschenpost_warehouse_id_hint") %></span>
  </p>
  <p><%= f.submit class: "btn" %></p>
<% end %>
