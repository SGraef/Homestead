<% content_for :title, @household.name %>
<% is_admin   = policy(@household).update? %>
<% is_current = (@household.id == current_household&.id) %>

<h1>
  <%= @household.name %>
  <% if is_current %><span class="pill"><%= t("household.current") %></span><% end %>
</h1>

<dl class="kv">
  <dt><%= t("household.timezone") %></dt><dd><%= @household.timezone %></dd>
  <% if @household.postal_code.present? %>
    <dt><%= t("household.postcode") %></dt><dd><%= @household.postal_code %></dd>
  <% end %>
</dl>

<p style="display:flex;gap:var(--sp-1);flex-wrap:wrap;margin:var(--sp-2) 0">
  <% unless is_current %>
    <%= button_to t("household.use"), switch_household_path(@household),
                  method: :post, class: "btn btn-sm",
                  form: { style: "display:inline" } %>
  <% end %>
  <%= link_to t("common.edit"), edit_household_path(@household),
              class: "btn btn-sm secondary" %>
  <% if is_current %>
    <%= link_to t("inbound_email.nav_link"), inbound_email_sources_path,
                class: "btn btn-sm secondary" %>
  <% end %>
  <% unless is_admin && @household.memberships.where(role: "admin").count == 1 %>
    <%= button_to t("household.leave"), leave_household_path(@household),
                  method: :delete, class: "btn btn-sm warn",
                  data: { turbo_confirm: t("household.leave_confirm") },
                  form: { style: "display:inline" } %>
  <% end %>
  <% if is_admin %>
    <%= button_to t("common.delete"), household_path(@household),
                  method: :delete, class: "btn btn-sm warn",
                  data: { turbo_confirm: t("household.delete_confirm") },
                  form: { style: "display:inline" } %>
  <% end %>
</p>

<h2><%= t("household.members") %></h2>
<ul style="list-style:none;padding:0">
  <% @household.memberships.includes(:user).each do |m| %>
    <li class="card card-flat" style="margin-bottom:var(--sp-1);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:var(--sp-2)">
      <span>
        <%= m.user.email %>
        <% if m.user_id == current_user.id %>
          <span class="caption">(<%= t("household.you") %>)</span>
        <% end %>
      </span>

      <span style="display:flex;gap:var(--sp-1);align-items:center;flex-wrap:wrap">
        <% if is_admin %>
          <%= form_with url: household_membership_path(@household, m),
                        method: :patch, local: true,
                        style: "display:inline-flex;gap:var(--sp-1)" do |f| %>
            <%= f.select "membership[role]",
                         Membership::ROLES.map { |r| [t("household.roles.#{r}"), r] },
                         { selected: m.role } %>
            <%= f.submit t("common.save"), class: "btn btn-sm secondary" %>
          <% end %>
          <%= button_to t("common.delete"), household_membership_path(@household, m),
                        method: :delete, class: "btn btn-sm warn",
                        data: { turbo_confirm: t("household.remove_member_confirm") },
                        form: { style: "display:inline" } %>
        <% else %>
          <span class="pill"><%= t("household.roles.#{m.role}") %></span>
        <% end %>
      </span>
    </li>
  <% end %>
</ul>

<% if is_admin %>
  <h3><%= t("household.add_member") %></h3>
  <%= form_with url: household_memberships_path(@household), local: true do |f| %>
    <p>
      <%= f.email_field "membership[email]", placeholder: "user@example.com", required: true %>
      <%= f.select "membership[role]",
                   Membership::ROLES.map { |r| [t("household.roles.#{r}"), r] },
                   { selected: "member" } %>
      <%= f.submit t("household.invite"), class: "btn" %>
    </p>
  <% end %>
<% end %>
