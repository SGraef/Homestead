<%= tag.div id: dom_id(todo_comment), class: "card card-flat", style: "margin-bottom:var(--sp-1)" do %>
  <div class="caption">
    <%= member_name(todo_comment.user) %> · <%= l(todo_comment.created_at, format: :short) %>
  </div>
  <div><%= simple_format(todo_comment.body) %></div>
  <% if (suggestion = comment_date_suggestion(todo_comment)) %>
    <div class="card card-flat" style="margin-top:var(--sp-1)">
      <span class="caption">
        <%= t("calendar.suggestion.detected",
               when: suggestion.all_day? ? l(suggestion.date, format: :long) :
                     "#{l(suggestion.date, format: :long)} #{format('%<h>02d:%<m>02d', h: suggestion.hour, m: suggestion.min || 0)}") %>
      </span>
      <%= button_to t("calendar.suggestion.confirm"),
                    confirm_event_todo_comment_path(todo_comment.todo, todo_comment),
                    method: :post, class: "btn btn-sm", form: { style: "display:inline" } %>
      <%= button_to t("calendar.suggestion.dismiss"),
                    dismiss_suggestion_todo_comment_path(todo_comment.todo, todo_comment),
                    method: :post, class: "btn btn-sm tertiary", form: { style: "display:inline" } %>
    </div>
  <% end %>
  <%# `interactive` is only set on page-load render — never in a broadcast,
      where there is no current_user (calling it would raise in Sorcery). %>
  <% if local_assigns[:interactive] && current_user && policy(todo_comment).destroy? %>
    <%= button_to t("common.delete"), todo_comment_path(todo_comment.todo, todo_comment),
                  method: :delete, class: "btn btn-sm tertiary", form: { style: "display:inline" } %>
  <% end %>
<% end %>
