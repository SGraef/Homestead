<%= form_with model: todo, local: true do |f| %>
  <% if todo.errors.any? %>
    <div class="flash alert"><%= todo.errors.full_messages.to_sentence %></div>
  <% end %>
  <p><%= f.label :title %><br><%= f.text_field :title, required: true, style: "width:100%" %></p>
  <p><%= f.label :description %><br><%= f.text_area :description, rows: 4, style: "width:100%" %></p>
  <p><%= f.label :due_on, t("todo.due_on") %><br><%= f.date_field :due_on %></p>
  <p><%= f.submit class: "btn" %></p>
<% end %>
