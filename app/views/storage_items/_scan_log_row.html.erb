<li class="scan-log-row" style="display:flex;gap:var(--sp-3);align-items:center;padding:var(--sp-2) var(--sp-3);border-radius:var(--radius-md);background:var(--bg-2)">
  <span style="flex:1">
    <strong><%= item.product.name %></strong>
    <% if item.product.brand.present? %><span class="caption"> · <%= item.product.brand %></span><% end %>
  </span>
  <span class="pill"><%= item.quantity %> <%= t("product.units.#{item.product.unit}", default: item.product.unit) %></span>
  <span class="caption"><%= item.location&.name %></span>
  <%= link_to t("common.edit"), edit_storage_item_path(item),
              class: "btn btn-sm tertiary",
              data: { turbo_frame: "_top" } %>
</li>
