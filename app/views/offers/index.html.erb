<% content_for :title, t("offer.title") %>
<h1><%= t("offer.title") %></h1>

<p class="caption">
  <%= t("offer.intro") %>
  <% if @postal_code.present? %>
    · <%= t("offer.postcode") %>: <strong><%= @postal_code %></strong>
  <% end %>
</p>

<div style="display:flex;gap:var(--sp-2);flex-wrap:wrap;align-items:center;margin-bottom:var(--sp-3)">
  <%= form_with url: offers_path, method: :get, local: true,
                style: "display:flex;gap:var(--sp-1);flex:1 1 14rem" do %>
    <%= text_field_tag :q, params[:q], placeholder: t("offer.search_placeholder"),
                       style: "flex:1" %>
    <%= submit_tag t("offer.filter"), class: "btn btn-sm secondary" %>
  <% end %>

  <% if @postal_code.present? %>
    <%= button_to t("offer.sync_now"), sync_offers_path, method: :post,
                  class: "btn btn-sm" %>
    <%= button_to t("offer.reset"), reset_offers_path, method: :post,
                  class: "btn btn-sm secondary",
                  data: { turbo_confirm: t("offer.reset_confirm") } %>
  <% else %>
    <%= link_to t("offer.set_postcode"), edit_household_path(current_household),
                class: "btn btn-sm" %>
  <% end %>
  <%= link_to t("offer.manual.add_button"), new_manual_offer_path,
              class: "btn btn-sm secondary" %>
  <%= link_to t("offer.categories.manage_button"), offer_categories_path,
              class: "btn btn-sm secondary" %>
</div>

<% if @offers.empty? %>
  <div class="card card-flat">
    <p>
      <% if @postal_code.blank? %>
        <%= t("offer.empty_no_postcode") %>
      <% else %>
        <%= t("offer.empty") %>
      <% end %>
    </p>
  </div>
<% else %>
  <% @offers_by_category.each do |category, offers_in_cat| %>
    <%# `<details>` gives us free expand/collapse with no JS. Open by
        default so the page renders unchanged on first load; the user
        clicks the summary to collapse a category and the browser
        remembers the state for that page load. %>
    <details class="offer-category" open
             style="margin-top:var(--sp-3)">
      <summary style="cursor:pointer;list-style:none">
        <span style="display:inline-flex;align-items:center;gap:var(--sp-1)">
          <span class="offer-category__chevron" aria-hidden="true">▾</span>
          <h2 style="display:inline;margin:0;font-size:var(--fs-lg)">
            <%= category.presence || t("offer.no_category") %>
          </h2>
          <span class="caption" style="font-weight:400">
            (<%= t("offer.count", count: offers_in_cat.size) %>)
          </span>
        </span>
      </summary>
      <div class="grid" style="margin-top:var(--sp-2)">
        <% offers_in_cat.each do |o| %>
        <% watched = offer_watched?(o) %>
        <div class="card card-elev <%= "offer-card--watched" if watched %>">
        <% if watched %>
          <span class="pill offer-card__watched-pill"
                title="<%= t("offer.watchlist.matched_help") %>">
            ★ <%= t("offer.watchlist.matched_label") %>
          </span>
        <% end %>

        <% if o.image_url.present? %>
          <p style="margin:0 0 var(--sp-2)">
            <img src="<%= o.image_url %>" alt=""
                 style="max-height:120px;border-radius:var(--radius-md)" loading="lazy">
          </p>
        <% end %>

        <div class="eyebrow"><%= o.retailer_name %></div>
        <h3 style="margin:.25rem 0">
          <% if o.product %>
            <%= link_to o.title, o.product %>
          <% else %>
            <%= o.title %>
          <% end %>
        </h3>

        <p class="mono" style="font-size:var(--fs-lg);margin:.25rem 0">
          <strong><%= number_to_currency(o.price, unit: o.currency.presence || "EUR") %></strong>
          <% if o.regular_price_cents %>
            <span class="caption" style="text-decoration:line-through">
              <%= number_to_currency(o.regular_price_cents / 100.0,
                                     unit: o.currency.presence || "EUR") %>
            </span>
          <% end %>
          <% if (pct = o.discount_percent) %>
            <span class="pill warn">−<%= pct %>%</span>
          <% end %>
        </p>

        <p class="caption" style="margin:.25rem 0">
          <% if o.quantity_text.present? %><%= o.quantity_text %><% end %>
          <% if o.brand.present? %> · <%= o.brand %><% end %>
          <% if o.category.present? %> · <%= o.category %><% end %>
        </p>

        <p class="caption" style="margin:.25rem 0">
          <% if o.valid_from && o.valid_until %>
            <%= t("offer.valid_range", from: l(o.valid_from), to: l(o.valid_until)) %>
          <% elsif o.valid_until %>
            <%= t("offer.valid_until", to: l(o.valid_until)) %>
          <% end %>
        </p>

        <p style="margin:var(--sp-2) 0 0;display:flex;gap:var(--sp-1);flex-wrap:wrap">
          <%= button_to t("offer.add_to_list"),
                        add_to_list_offer_path(o),
                        method: :post, class: "btn btn-sm",
                        form: { style: "display:inline" } %>
          <%# Block by full offer title -- user can refine the pattern
              afterwards in the "Blocked patterns" management section. %>
          <%= button_to t("offer.block"),
                        offer_blocklist_entries_path(entry: { pattern: o.title }),
                        method: :post, class: "btn btn-sm warn",
                        data: { turbo_confirm: t("offer.block_confirm", pattern: o.title) },
                        form: { style: "display:inline" } %>
          <% if o.source_url.present? && o.source != "manual" %>
            <%= link_to t("offer.view_on_marktguru"), o.source_url,
                        class: "btn btn-sm secondary",
                        target: "_blank", rel: "noopener" %>
          <% end %>
          <% if o.source == "manual" %>
            <%= link_to t("common.edit"), edit_manual_offer_path(o),
                        class: "btn btn-sm secondary" %>
            <%= button_to t("common.delete"), manual_offer_path(o), method: :delete,
                          class: "btn btn-sm warn",
                          data: { turbo_confirm: t("offer.manual.delete_confirm") },
                          form: { style: "display:inline" } %>
          <% end %>
        </p>
          <% if o.product.nil? %>
            <p class="caption" style="margin:.25rem 0 0">
              <%= t("offer.will_create_product") %>
            </p>
          <% end %>
        </div>
      <% end %>
      </div>
    </details>
  <% end %>
<% end %>

<details class="card" style="margin-top:var(--sp-3)" <%= "open" if current_household.offer_watchlist_entries.any? %>>
  <summary>
    <strong>★ <%= t("offer.watchlist.title") %></strong>
    <span class="caption">
      (<%= t("offer.watchlist.count", count: current_household.offer_watchlist_entries.size) %>)
    </span>
  </summary>
  <p class="caption"><%= t("offer.watchlist.intro") %></p>

  <% watch_entries = current_household.offer_watchlist_entries.ordered %>
  <% if watch_entries.any? %>
    <ul style="list-style:none;padding:0">
      <% watch_entries.each do |e| %>
        <li class="card card-flat" style="margin-bottom:var(--sp-1);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:var(--sp-2)">
          <code><%= e.pattern %></code>
          <%= button_to t("offer.watchlist.remove"),
                        offer_watchlist_entry_path(e),
                        method: :delete, class: "btn btn-sm secondary",
                        form: { style: "display:inline" } %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="caption"><%= t("offer.watchlist.empty") %></p>
  <% end %>

  <%= form_with url: offer_watchlist_entries_path, local: true,
                style: "display:flex;gap:var(--sp-1);flex-wrap:wrap;align-items:flex-end;margin-top:var(--sp-2)" do |f| %>
    <span style="flex:1 1 14rem">
      <%= label_tag "entry[pattern]", t("offer.watchlist.pattern_label") %><br>
      <%= text_field_tag "entry[pattern]", nil,
                         placeholder: t("offer.watchlist.pattern_placeholder"),
                         required: true, style: "width:100%" %>
    </span>
    <%= f.submit t("offer.watchlist.add"), class: "btn btn-sm" %>
  <% end %>
</details>

<details class="card" style="margin-top:var(--sp-3)">
  <summary>
    <strong><%= t("offer.retailer_filter.title") %></strong>
    <span class="caption">
      (<%= t("offer.retailer_filter.count", count: current_household.offer_retailer_filters.size) %>)
    </span>
  </summary>
  <p class="caption"><%= t("offer.retailer_filter.intro") %></p>

  <%
    # Union of (already-stored offer retailers) and (retailers in the
    # allow-list but not currently surfacing offers) so a user who
    # pre-selected something gone from the feed still sees it ticked.
    known_retailers = current_household.offers.distinct.pluck(:retailer_name).compact
    selected_set    = current_household.offer_retailer_filters.pluck(:retailer).to_set
    options         = (known_retailers + selected_set.to_a).uniq.sort_by(&:downcase)
  %>

  <% if options.empty? %>
    <p class="caption"><%= t("offer.retailer_filter.no_known") %></p>
  <% else %>
    <%= form_with url: bulk_offer_retailer_filters_path, method: :put, local: true do %>
      <%# Always send at least the empty marker so an unchecked-everything
          submission still clears the allow-list (without this, the
          `retailers[]` param would be missing entirely). %>
      <%= hidden_field_tag "retailers[]", "" %>

      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(12rem,1fr));gap:var(--sp-1);margin:var(--sp-2) 0">
        <% options.each do |name| %>
          <label class="card card-flat" style="display:flex;gap:var(--sp-2);align-items:center;padding:var(--sp-1) var(--sp-2);margin:0;cursor:pointer">
            <%= check_box_tag "retailers[]", name, selected_set.include?(name) %>
            <span><%= name %></span>
          </label>
        <% end %>
      </div>

      <p class="caption"><%= t("offer.retailer_filter.bulk_hint") %></p>
      <%= submit_tag t("offer.retailer_filter.save"), class: "btn btn-sm" %>
    <% end %>
  <% end %>
</details>

<details class="card" style="margin-top:var(--sp-3)">
  <summary>
    <strong><%= t("offer.blocklist.title") %></strong>
    <span class="caption">
      (<%= t("offer.blocklist.count", count: current_household.offer_blocklist_entries.size) %>)
    </span>
  </summary>
  <p class="caption"><%= t("offer.blocklist.intro") %></p>

  <% entries = current_household.offer_blocklist_entries.ordered %>
  <% if entries.any? %>
    <ul style="list-style:none;padding:0">
      <% entries.each do |e| %>
        <li class="card card-flat" style="margin-bottom:var(--sp-1);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:var(--sp-2)">
          <span>
            <code><%= e.pattern %></code>
            <% if e.reason.present? %><span class="caption">— <%= e.reason %></span><% end %>
          </span>
          <%= button_to t("offer.blocklist.remove"),
                        offer_blocklist_entry_path(e),
                        method: :delete, class: "btn btn-sm secondary",
                        form: { style: "display:inline" } %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="caption"><%= t("offer.blocklist.empty") %></p>
  <% end %>

  <%= form_with url: offer_blocklist_entries_path, local: true,
                style: "display:flex;gap:var(--sp-1);flex-wrap:wrap;align-items:flex-end;margin-top:var(--sp-2)" do |f| %>
    <span style="flex:1 1 12rem">
      <%= label_tag "entry[pattern]", t("offer.blocklist.pattern_label") %><br>
      <%= text_field_tag "entry[pattern]", nil,
                         placeholder: t("offer.blocklist.pattern_placeholder"),
                         required: true, style: "width:100%" %>
    </span>
    <span style="flex:1 1 10rem">
      <%= label_tag "entry[reason]", t("offer.blocklist.reason_label") %><br>
      <%= text_field_tag "entry[reason]", nil,
                         placeholder: t("offer.blocklist.reason_placeholder"),
                         style: "width:100%" %>
    </span>
    <%= f.submit t("offer.blocklist.add"), class: "btn btn-sm" %>
  <% end %>
</details>
