# The AsynchronousMetricStream class provides SDK internal functionality that is not a part of the
# public API. It extends MetricStream to support asynchronous instruments.
#
# pkg:gem/opentelemetry-metrics-sdk#lib/opentelemetry/sdk/metrics/state/asynchronous_metric_stream.rb:15
class OpenTelemetry::SDK::Metrics::State::AsynchronousMetricStream < ::OpenTelemetry::SDK::Metrics::State::MetricStream
  # pkg:gem/opentelemetry-metrics-sdk#lib/opentelemetry/sdk/metrics/state/asynchronous_metric_stream.rb:18
  def initialize(name, description, unit, instrument_kind, meter_provider, instrumentation_scope, aggregation, callback, timeout, attributes, exemplar_filter, exemplar_reservoir); end

  # When collect, if there are asynchronous SDK Instruments involved, their callback functions will be triggered.
  # Related spec: https://github.com/open-telemetry/opentelemetry-specification/blob/main/specification/metrics/sdk.md#collect
