# {AsynchronousInstrument} contains the common functionality shared across
# the asynchronous instruments SDK instruments.
#
# pkg:gem/opentelemetry-metrics-sdk#lib/opentelemetry/sdk/metrics/instrument/asynchronous_instrument.rb:13
class OpenTelemetry::SDK::Metrics::Instrument::AsynchronousInstrument
  # pkg:gem/opentelemetry-metrics-sdk#lib/opentelemetry/sdk/metrics/instrument/asynchronous_instrument.rb:16
  def initialize(name, unit, description, callback, instrumentation_scope, meter_provider, exemplar_filter, exemplar_reservoir); end

  # pkg:gem/opentelemetry-metrics-sdk#lib/opentelemetry/sdk/metrics/instrument/asynchronous_instrument.rb:84
  def add_attributes(attributes); end

  # The API MUST support creation of asynchronous instruments by passing zero or more callback functions
  # to be permanently registered to the newly created instrument.
  #
  # pkg:gem/opentelemetry-metrics-sdk#lib/opentelemetry/sdk/metrics/instrument/asynchronous_instrument.rb:55
  def init_callback(callback); end

  # Where the API supports registration of callback functions after asynchronous instrumentation creation,
  # the user MUST be able to undo registration of the specific callback after its registration by some means.
  #
  # pkg:gem/opentelemetry-metrics-sdk#lib/opentelemetry/sdk/metrics/instrument/asynchronous_instrument.rb:67
  def register_callback(callback); end

  # @api private
  #
  # pkg:gem/opentelemetry-metrics-sdk#lib/opentelemetry/sdk/metrics/instrument/asynchronous_instrument.rb:34
  def register_with_new_metric_store(metric_store, aggregation: T.unsafe(nil)); end

  # pkg:gem/opentelemetry-metrics-sdk#lib/opentelemetry/sdk/metrics/instrument/asynchronous_instrument.rb:80
  def timeout(timeout); end

  # pkg:gem/opentelemetry-metrics-sdk#lib/opentelemetry/sdk/metrics/instrument/asynchronous_instrument.rb:76
  def unregister(callback); end

  private

  # Adding the exemplar to reservoir
  # Only record the exemplar if exemplar_filter decide to sample/record it
  #
  # pkg:gem/opentelemetry-metrics-sdk#lib/opentelemetry/sdk/metrics/instrument/asynchronous_instrument.rb:98
  def exemplar_offer(value, attributes); end

  # update the observed value (after calling observe)
  # invoke callback will execute callback and export metric_data that is observed
  #
  # pkg:gem/opentelemetry-metrics-sdk#lib/opentelemetry/sdk/metrics/instrument/asynchronous_instrument.rb:92
  def update(timeout, attributes); end
end

