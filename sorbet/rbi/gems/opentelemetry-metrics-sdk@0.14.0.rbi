  def collect(start_time, end_time); end

  # pkg:gem/opentelemetry-metrics-sdk#lib/opentelemetry/sdk/metrics/state/asynchronous_metric_stream.rb:52
  def invoke_callback(timeout, attributes); end

  private

  # pkg:gem/opentelemetry-metrics-sdk#lib/opentelemetry/sdk/metrics/state/asynchronous_metric_stream.rb:84
  def safe_guard_callback(callback, timeout: T.unsafe(nil)); end
end

