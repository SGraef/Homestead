# PeriodicMetricReader provides a minimal example implementation.
#
# pkg:gem/opentelemetry-metrics-sdk#lib/opentelemetry/sdk/metrics/export/periodic_metric_reader.rb:12
class OpenTelemetry::SDK::Metrics::Export::PeriodicMetricReader < ::OpenTelemetry::SDK::Metrics::Export::MetricReader
  # Returns a new instance of the {PeriodicMetricReader}.
  #
  # @param [Integer] export_interval_millis the maximum interval time.
  #   Defaults to the value of the OTEL_METRIC_EXPORT_INTERVAL environment
  #   variable, if set, or 60_000.
  # @param [Integer] export_timeout_millis the maximum export timeout.
  #   Defaults to the value of the OTEL_METRIC_EXPORT_TIMEOUT environment
  #   variable, if set, or 30_000.
  # @param [MetricReader] exporter the (duck type) MetricReader to where the
  #   recorded metrics are pushed after certain interval.
  #
  # @return a new instance of the {PeriodicMetricReader}.
  #
  # pkg:gem/opentelemetry-metrics-sdk#lib/opentelemetry/sdk/metrics/export/periodic_metric_reader.rb:25
  def initialize(export_interval_millis: T.unsafe(nil), export_timeout_millis: T.unsafe(nil), exporter: T.unsafe(nil)); end

  # pkg:gem/opentelemetry-metrics-sdk#lib/opentelemetry/sdk/metrics/export/periodic_metric_reader.rb:81
  def after_fork; end

  # Check both @thread and @continue object to determine if current
  # PeriodicMetricReader is still alive. If one of them is true/alive,
  # then PeriodicMetricReader is determined as alive
  #
  # pkg:gem/opentelemetry-metrics-sdk#lib/opentelemetry/sdk/metrics/export/periodic_metric_reader.rb:91
  def alive?; end

  # Export all metrics to the configured `Exporter` that have not yet
  # been exported.
  #
  # This method should only be called in cases where it is absolutely
  # necessary, such as when using some FaaS providers that may suspend
  # the process after an invocation, but before the `PeriodicMetricReader` exports
  # the completed metrics.
  #
  # @param [optional Numeric] timeout An optional timeout in seconds.
  # @return [Integer] SUCCESS if no error occurred, FAILURE if a
  #   non-specific failure occurred.
  #
  # pkg:gem/opentelemetry-metrics-sdk#lib/opentelemetry/sdk/metrics/export/periodic_metric_reader.rb:74
  def force_flush(timeout: T.unsafe(nil)); end

  # Shuts the @thread down and set @continue to false; it will block
  # until the shutdown thread is finished.
  #
  # @param [optional Numeric] timeout An optional timeout in seconds.
  # @return [Integer] SUCCESS if no error occurred, FAILURE if a
  #   non-specific failure occurred.
  #
  # pkg:gem/opentelemetry-metrics-sdk#lib/opentelemetry/sdk/metrics/export/periodic_metric_reader.rb:48
  def shutdown(timeout: T.unsafe(nil)); end

  private

  # Helper function for the defined exporter to export metrics.
  # It only exports if the collected metrics are not an empty array (collect returns an Array).
  #
  # @param [optional Numeric] timeout An optional timeout in seconds.
  # @return [Integer] SUCCESS if no error occurred, FAILURE if a
  #   non-specific failure occurred
  #
  # pkg:gem/opentelemetry-metrics-sdk#lib/opentelemetry/sdk/metrics/export/periodic_metric_reader.rb:123
  def export(timeout: T.unsafe(nil)); end

  # pkg:gem/opentelemetry-metrics-sdk#lib/opentelemetry/sdk/metrics/export/periodic_metric_reader.rb:136
  def lock(&block); end

  # pkg:gem/opentelemetry-metrics-sdk#lib/opentelemetry/sdk/metrics/export/periodic_metric_reader.rb:132
  def report_result(result_code); end

  # Start a thread that continously export metrics within fixed duration.
  # The wait mechanism is using to check @mutex lock with conditional variable
  #
  # pkg:gem/opentelemetry-metrics-sdk#lib/opentelemetry/sdk/metrics/export/periodic_metric_reader.rb:99
  def start; end
end

