  def find_histogram_bucket; end

  # Uses a uniformly-weighted sampling algorithm based on the number of samples the reservoir has seen
  # Fill the buckets array first then randomly override existing bucket
  #
  # pkg:gem/opentelemetry-metrics-sdk#lib/opentelemetry/sdk/metrics/exemplar/simple_fixed_size_exemplar_reservoir.rb:29
  def offer(value: T.unsafe(nil), timestamp: T.unsafe(nil), attributes: T.unsafe(nil), context: T.unsafe(nil)); end

  # pkg:gem/opentelemetry-metrics-sdk#lib/opentelemetry/sdk/metrics/exemplar/simple_fixed_size_exemplar_reservoir.rb:47
  def reset; end
end

