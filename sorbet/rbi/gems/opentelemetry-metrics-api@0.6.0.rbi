# No-op implementation of a meter provider.
#
# pkg:gem/opentelemetry-metrics-api#lib/opentelemetry/metrics/meter_provider.rb:10
class OpenTelemetry::Metrics::MeterProvider
  # Returns a {Meter} instance.
  #
  # @param [String] name Instrumentation package name
  # @param [optional String] version Instrumentation package version
  #
  # @return [Meter]
  #
  # pkg:gem/opentelemetry-metrics-api#lib/opentelemetry/metrics/meter_provider.rb:17
  def meter(name, version: T.unsafe(nil)); end
end

